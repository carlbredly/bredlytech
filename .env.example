# Copier vers .env.local — sur Vercel : les mêmes clés dans Settings → Environment Variables (Production)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin (/admin/login)
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Resend — https://resend.com/api-keys (idem sur Vercel → Environment Variables)
RESEND_API_KEY=
# Avec l’expéditeur par défaut onboarding@resend.dev : mettre ICI l’e-mail du compte Resend (souvent ton Gmail) — pas une autre adresse.
# Pour envoyer vers d’autres boîtes : domaine vérifié sur resend.com/domains puis RESEND_FROM_EMAIL ci‑dessous.
CONTACT_NOTIFY_EMAIL=
# RESEND_FROM_EMAIL=Bredly <contact@ton-domaine-verifie.com>
