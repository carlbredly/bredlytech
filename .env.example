# Copier vers .env.local

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin (/admin/login)
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Resend — https://resend.com/api-keys (reçois une copie dans ta boîte)
RESEND_API_KEY=
# Une ou plusieurs adresses (séparées par des virgules) = même contenu pour chacune
CONTACT_NOTIFY_EMAIL=toi@exemple.com
# Optionnel : expéditeur (domaine vérifié ou onboarding@resend.dev en test)
# RESEND_FROM_EMAIL=Bredly <onboarding@resend.dev>
